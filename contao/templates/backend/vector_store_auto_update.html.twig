{% extends "@Contao/be_main.html.twig" %}

{% block main_content %}
    <style>
        .vsau-badge { display: inline-block; padding: 2px 8px; border-radius: 3px; font-size: 12px; font-weight: bold; color: #fff; }
        .vsau-badge.green { background: #43a047; }
        .vsau-badge.red { background: #e53935; }
        .vsau-badge.yellow { background: #f59e0b; }
        .vsau-badge.blue { background: #2196f3; }
        .vsau-badge.grey { background: #757575; }
        .vsau-config { margin-bottom: 24px; }
        .vsau-meta { margin: 8px 0; }
        .vsau-meta dt { font-weight: bold; display: inline-block; min-width: 160px; }
        .vsau-meta dd { display: inline; margin: 0; }
        .vsau-meta div { margin: 4px 0; }
        table.vsau-log { width: 100%; border-collapse: collapse; margin-top: 8px; }
        table.vsau-log th, table.vsau-log td { border: 1px solid var(--border, #ddd); padding: 4px 8px; text-align: left; font-size: 12px; }
    </style>

    {% if configs is empty %}
        <div class="tl_info">
            No configuration has automatic sync enabled yet. Enable it in
            <em>AI Tools → OpenAI Configuration → Automatic vector store sync</em>.
        </div>
    {% endif %}

    {% for config in configs %}
        <div class="tl_box vsau-config">
            <h2>{{ config.title }}</h2>

            {# License status badge #}
            <div class="vsau-meta">
                <div>
                    <dt>Premium license</dt>
                    <dd>
                        {% if config.license_active %}
                            <span class="vsau-badge green">active</span>
                            {% if config.premium_license_valid_until > 0 %}
                                <span>expires {{ config.premium_license_valid_until|date('Y-m-d') }}</span>
                            {% endif %}
                        {% elseif config.premium_license_status == 'error' %}
                            <span class="vsau-badge yellow">error</span>
                            <span>Could not reach license server — sync allowed under grace period.</span>
                        {% else %}
                            <span class="vsau-badge red">{{ config.premium_license_status|default('inactive') }}</span>
                            <a href="{{ purchase_url }}" target="_blank" rel="noopener" class="tl_submit">Buy premium license</a>
                        {% endif %}
                    </dd>
                </div>

                {# Cron health #}
                <div>
                    <dt>Cron status</dt>
                    <dd>
                        {% if config.cron_status == 'never' %}
                            <span class="vsau-badge red">no runs recorded</span>
                        {% elseif config.cron_status == 'healthy' %}
                            <span class="vsau-badge green">healthy</span>
                            <span>last seen {{ config.auto_update_last_run|date('Y-m-d H:i:s') }}</span>
                        {% else %}
                            <span class="vsau-badge yellow">stale</span>
                            <span>last ping {{ config.auto_update_last_run|date('Y-m-d H:i:s') }} — your server cron may have stopped.</span>
                        {% endif %}
                    </dd>
                </div>

                {# Last sync result #}
                <div>
                    <dt>Last sync</dt>
                    <dd>
                        {% set st = config.auto_update_last_status %}
                        {% if st == 'success' %}
                            <span class="vsau-badge green">success</span>
                        {% elseif st == 'error' %}
                            <span class="vsau-badge red">error</span>
                        {% elseif st == 'running' %}
                            <span class="vsau-badge blue">running</span>
                        {% elseif st == 'queued' %}
                            <span class="vsau-badge blue">queued — refresh in a few minutes</span>
                        {% else %}
                            <span class="vsau-badge grey">never run</span>
                        {% endif %}
                        {% if config.auto_update_last_message %}
                            <div class="tl_gray">{{ config.auto_update_last_message }}</div>
                        {% endif %}
                    </dd>
                </div>

                <div>
                    <dt>Schedule</dt>
                    <dd>
                        <code>{{ config.auto_update_schedule }}</code>
                        {% if config.next_run %}<span>(next: {{ config.next_run|date('Y-m-d H:i') }})</span>{% endif %}
                    </dd>
                </div>
            </div>

            {# Cron "never ran" warning #}
            {% if config.cron_status == 'never' %}
                <p class="tl_gerror">
                    No runs recorded — your server cron job has not triggered yet.
                    Add <code>* * * * * [php] [project]/vendor/bin/contao-console contao:cron</code> to your server cron.
                </p>
            {% endif %}

            {# Prerequisite warnings #}
            {% for warning in config.warnings %}
                <p class="tl_gerror">{{ warning }}</p>
            {% endfor %}

            {# Manual trigger — only when enabled AND licensed #}
            {% if config.license_active %}
                <form method="post" action="{{ path('vector_store_auto_update') }}" style="margin-top: 12px;">
                    <input type="hidden" name="REQUEST_TOKEN" value="{{ request_token }}">
                    <input type="hidden" name="config_id" value="{{ config.id }}">
                    <button type="submit" class="tl_submit"
                            {% if config.auto_update_last_status in ['running', 'queued'] %}disabled{% endif %}>
                        Run sync now
                    </button>
                </form>
            {% endif %}
        </div>
    {% endfor %}

    {# Run history #}
    <div class="tl_box">
        <h2>Recent runs</h2>
        {% if log is empty %}
            <p class="tl_gray">No runs recorded yet.</p>
        {% else %}
            <table class="vsau-log">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Pages</th>
                        <th>Tokens in</th>
                        <th>Tokens out</th>
                        <th>Duration</th>
                        <th>File ID</th>
                        <th>Message</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in log %}
                        <tr>
                            <td>{{ row.run_at|date('Y-m-d H:i:s') }}</td>
                            <td>
                                {% if row.status == 'success' %}
                                    <span class="vsau-badge green">success</span>
                                {% else %}
                                    <span class="vsau-badge red">{{ row.status }}</span>
                                {% endif %}
                            </td>
                            <td>{{ row.pages }}</td>
                            <td>{{ row.tokens_in }}</td>
                            <td>{{ row.tokens_out }}</td>
                            <td>{{ row.duration }}s</td>
                            <td><code>{{ row.file_id }}</code></td>
                            <td>{{ row.message }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>
{% endblock %}
