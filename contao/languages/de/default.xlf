                <target>Noch keine Konfiguration mit automatischer Synchronisierung aktiviert.</target>
            </trans-unit>
            <trans-unit id="MSC.vsau_no_config_hint">
                <source>Enable it in AI Tools → OpenAI Configuration → Automatic vector store sync.</source>
                <target>Aktivieren Sie diese unter KI-Tools → OpenAI-Konfiguration → Automatische Vector-Store-Synchronisierung.</target>
            </trans-unit>
