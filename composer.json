{
  "name": "juhe-it-solutions/contao-openai-assistant",
  "description": "OpenAI Responses API integration for Contao CMS",
  "type": "contao-bundle",
  "homepage": "https://www.juhe-it-solutions.at",
  "license": "LGPL-3.0-or-later AND proprietary",
  "authors": [
    {
      "name": "JUHE IT-solutions",
      "email": "office@juhe-it-solutions.at",
      "homepage": "https://www.juhe-it-solutions.at",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.4",
    "contao/core-bundle": "^6.0",
    "symfony/http-client": "^7.4 || ^8.0",
    "symfony/rate-limiter": "^7.4 || ^8.0"
  },
  "autoload": {
    "psr-4": {
      "JuheItSolutions\\ContaoOpenaiAssistant\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "JuheItSolutions\\ContaoOpenaiAssistant\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "contao/easy-coding-standard": "^6.13",
    "symplify/easy-coding-standard": "13.2.3",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^12.0"
  },
  "extra": {
    "contao-manager-plugin": "JuheItSolutions\\ContaoOpenaiAssistant\\ContaoManagerPlugin"
  },
  "keywords": ["contao", "openai", "assistant", "ai", "chatbot"],
  "minimum-stability": "RC",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "contao-components/installer": true,
      "php-http/discovery": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
